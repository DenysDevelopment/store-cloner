# ===== Source store (магазин-источник) =====
SOURCE_SHOP=laptopguru-eu.myshopify.com

# Вариант 1: Access Token (если есть)
SOURCE_ACCESS_TOKEN=

# Вариант 2: Client Credentials (Dev Dashboard)
SOURCE_CLIENT_ID=
SOURCE_CLIENT_SECRET=

# ===== Target store (целевой магазин) =====
TARGET_SHOP=your-target-store.myshopify.com

# Вариант 1: Access Token (если есть)
TARGET_ACCESS_TOKEN=

# Вариант 2: Client Credentials (Dev Dashboard)
TARGET_CLIENT_ID=
TARGET_CLIENT_SECRET=

# ===== Settings =====
API_VERSION=2025-01
DATA_DIR=./data
RATE_LIMIT=2
LOG_LEVEL=info
